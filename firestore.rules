rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperadmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // Usuário lê o próprio perfil; superadmin lê todos
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isSuperadmin());
      allow write: if false; // somente via Admin SDK
    }

    // Instituições e unidades — leitura por autenticados, escrita só via Admin SDK
    match /institutions/{id} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /units/{unitId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // Logs de auditoria — somente superadmin lê, ninguém escreve pelo client
    match /audit_logs/{id} {
      allow read: if isSuperadmin();
      allow write: if false;
    }
  }
}
